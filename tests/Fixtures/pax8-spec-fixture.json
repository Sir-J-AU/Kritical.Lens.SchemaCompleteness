{
  "openapi": "3.0.1",
  "info": { "title": "Pax8 fixture", "version": "1.0" },
  "components": {
    "schemas": {
      "Pricing": {
        "type": "object",
        "properties": {
          "productId": { "type": "string" },
          "productName": { "type": "string" },
          "billingTerm": { "type": "string" },
          "unitOfMeasurement": { "type": "string" },
          "rates": { "type": "array", "items": { "$ref": "#/components/schemas/Rate" } }
        }
      },
      "Rate": {
        "type": "object",
        "properties": {
          "partnerBuyRate": { "type": "number" },
          "suggestedRetailPrice": { "type": "number" }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "street": { "type": "string" },
          "city": { "type": "string" }
        }
      }
    }
  }
}
